---
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Page not found — SAP Skill Hub</title>
    <style>
      body { margin: 0; font-family: Inter, system-ui, sans-serif; color: #111827; }
      main { max-width: 640px; margin: 15vh auto; padding: 32px; }
      h1 { font-size: 40px; margin-bottom: 12px; }
      p { color: #536078; line-height: 1.7; }
      a { color: #075ee8; }
    </style>
  </head>
  <body>
    <main>
      <h1>404</h1>
      <p>页面不存在，或对应的 Skill 已移动。<br />This page does not exist, or the skill has moved.</p>
      <p><a href={`${base}zh/`}>返回中文主页</a> · <a href={`${base}en/`}>English home</a></p>
    </main>
  </body>
</html>
