---
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <title>SAP Skill Hub</title>
  </head>
  <body>
    <main>
      <h1>SAP Skill Hub</h1>
      <p>正在选择语言… / Selecting language…</p>
      <p><a href={`${base}zh/`}>中文</a> · <a href={`${base}en/`}>English</a></p>
    </main>
    <script is:inline define:vars={{ base }}>
      const saved = localStorage.getItem("sap-skillhub-language");
      const locale = saved === "zh" || saved === "en"
        ? saved
        : navigator.language.toLowerCase().startsWith("zh") ? "zh" : "en";
      window.location.replace(`${base}${locale}/`);
    </script>
  </body>
</html>
